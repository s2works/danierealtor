{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/listings.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/listings",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=900, stale-while-revalidate=86400" }
      ]
    }
  ]
}
